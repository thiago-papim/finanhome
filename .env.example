# EmailJS - envio do resumo da simulação por email
# Crie uma conta em https://www.emailjs.com/ e configure o serviço e o template.
# No template, use as variáveis: {{nome}}, {{cpf}}, {{telefone}}, {{email}}, {{steps}}
# Ordem no email: nome, cpf, telefone, email, steps (cada step como "Label: Resposta")
#
# Create React App carrega o .env automaticamente (não precisa de dotenv).
# Copie este arquivo para .env e preencha os valores. Reinicie "npm start" após alterar.
REACT_APP_EMAILJS_SERVICE_ID=seu_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=seu_template_id
REACT_APP_EMAILJS_PUBLIC_KEY=sua_public_key
